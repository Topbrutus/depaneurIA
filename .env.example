# ============================================================
# .env.example — depaneurIA
# ============================================================
# Copier ce fichier en .env.local et renseigner les valeurs.
# Ne jamais commiter .env.local
# ============================================================

# Environnement d'exécution
NODE_ENV=development

# --- API ---
# URL de l'API back-end (utilisée par le front-end)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL de connexion PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/depaneuria_dev

# Clé de signature JWT (min. 32 caractères)
JWT_SECRET=change-me-with-a-long-random-secret

# --- OpenAI ---
# Clé API OpenAI pour l'assistant IA
OPENAI_API_KEY=sk-...

# --- Ports (optionnel — valeurs par défaut dans les apps) ---
PORT_WEB=3000
PORT_API=3001
